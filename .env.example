# Alfred — environment variables

# Anthropic API key (required for classifier + responder)
ANTHROPIC_API_KEY=sk-ant-...

# Initial contract mode (standard | extended). UI can toggle at runtime.
CONTRACT_MODE=standard

# Classifier confidence threshold below which extended-mode rules escalate.
CONFIDENCE_THRESHOLD=0.75

# Calendar staleness threshold in minutes (extended mode only).
CALENDAR_STALENESS_THRESHOLD_MINUTES=10

# Max emails to surface in the inbox pane.
GMAIL_MAX_MESSAGES=250

# Calendar horizon in days ahead.
CALENDAR_DAYS_AHEAD=14

# Comma-separated phrases that imply off-system context (extended mode signal).
OFF_SYSTEM_PATTERNS=as we discussed,per our call,as agreed,following our conversation,as promised,like I mentioned,per my last email,comme convenu,suite a notre echange
